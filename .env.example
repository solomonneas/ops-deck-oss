# Optional: shared secret between UI and sidecar. Leave unset for trust-by-network local use.
OPSDECK_API_KEY=

# Path to your OpenClaw workspace on the host. The sidecar mounts this read-only.
# Defaults to ./sample-workspace (a tiny seed shipped in the repo for first-run demos).
OPENCLAW_WORKSPACE=

# Note: VITE_* env vars (VITE_SIDECAR_BASE_URL, VITE_SEARCH_BASE_URL, etc.) are
# baked into the UI bundle at npm run build time. The bundled docker image uses
# localhost defaults. To customize, either:
#   - rebuild the UI image after editing your local .env
#   - or run `cd ui && npm run dev` for hot-reload with live config
